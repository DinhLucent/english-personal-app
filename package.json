{
  "name": "speakflow-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:env": "node scripts/check-env.mjs",
    "check:env:network": "node scripts/check-env.mjs --network",
    "check:speaking-curriculum": "node scripts/check-speaking-curriculum.mjs",
    "check:supabase:schema": "node scripts/check-supabase-schema.mjs",
    "smoke:local": "node scripts/smoke-local.mjs",
    "smoke:ai": "node scripts/smoke-ai.mjs",
    "verify:local": "npm run lint && npm run build && npm run check:speaking-curriculum && npm audit --omit=dev && npm run smoke:local",
    "visual:qa": "node scripts/visual-qa.mjs",
    "accessibility:smoke": "node scripts/accessibility-smoke.mjs",
    "interaction:qa": "node scripts/interaction-qa.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "animejs": "^4.5.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "openai": "^6.44.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
